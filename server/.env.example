# Переменные окружения сервера.
# Скопируй этот файл в .env и заполни своими значениями.
# Никогда не коммить .env в git!

# MongoDB — строка подключения
# Локально: mongodb://localhost:27017/game-dnd
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/game-dnd
MONGO_URI=mongodb://localhost:27017/game-dnd

# Секрет для подписи JWT-токенов — любая длинная случайная строка
JWT_SECRET=replace_this_with_a_long_random_secret

# Время жизни JWT (7d = 7 дней)
JWT_EXPIRES_IN=7d

# Порт сервера
PORT=3000
